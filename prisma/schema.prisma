generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL1")
}

model Account {
    id String @id @default(uuid()) @db.Uuid
    name String
    email String @unique
    password String

    @@map("accounts")
}
